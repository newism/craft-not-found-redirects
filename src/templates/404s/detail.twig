<div>
    <table class="data editable fullwidth">
        <tbody>
        {% if craft.app.sites.allSites|length > 1 %}
            <tr>
                <th scope="row" style="width: 1px; white-space: nowrap;">{{ 'Site'|t('app') }}</th>
                <td>{{ craft.app.sites.getSiteById(notFound.siteId).name ?? '' }}</td>
            </tr>
        {% endif %}
        <tr>
            <th scope="row" style="width: 1px; white-space: nowrap;">{{ 'URI'|t('not-found-redirects') }}</th>
            <td>{{ notFound.uri ?: '/' }}</td>
        </tr>
        <tr>
            <th scope="row" style="width: 1px; white-space: nowrap;">{{ 'Hits'|t('not-found-redirects') }}</th>
            <td>{{ notFound.hitCount }}</td>
        </tr>
        <tr>
            <th scope="row" style="width: 1px; white-space: nowrap;">{{ 'First Seen'|t('not-found-redirects') }}</th>
            <td>{{ notFound.dateCreated ? notFound.dateCreated|datetime : '-' }}</td>
        </tr>
        <tr>
            <th scope="row" style="width: 1px; white-space: nowrap;">{{ 'Last Seen'|t('not-found-redirects') }}</th>
            <td>{{ notFound.hitLastTime ? notFound.hitLastTime|datetime : '-' }}</td>
        </tr>
        <tr>
            <th scope="row" style="width: 1px; white-space: nowrap;">{{ 'Handled'|t('not-found-redirects') }}</th>
            <td>{{ handledHtml|raw }}</td>
        </tr>
        {% if redirectInfo %}
            <tr>
                <th scope="row" style="width: 1px; white-space: nowrap;">{{ 'Redirect'|t('not-found-redirects') }}</th>
                <td>
                    <a href="{{ redirectInfo.cpEditUrl }}">
                        {{ redirectInfo.from ?: '/' }}
                        {% if redirectInfo.statusCode != 410 %}
                            <span class="light">→</span> {{ redirectInfo.to ?: '/' }}
                        {% endif %}
                        <span class="light">({{ redirectInfo.statusCode }})</span>
                    </a>
                </td>
            </tr>
        {% endif %}
        </tbody>
    </table>
</div>

<hr>

<h2>{{ 'Referrers'|t('not-found-redirects') }}</h2>

{% if notFound.referrerCount > 0 %}
    {% do view.registerAssetBundle('craft\\web\\assets\\admintable\\AdminTableAsset') %}
    <div id="referrers-vue-admin-table"></div>
    {% js %}
    (() => {
        const columns = [
            { name: '__slot:title', title: Craft.t('not-found-redirects', 'Referrer'), sortField: true },
            { name: 'hitCount', title: Craft.t('not-found-redirects', 'Hits'), sortField: true },
            { name: 'hitLastTime', title: Craft.t('not-found-redirects', 'Last Hit'), sortField: true },
        ];

        new Craft.VueAdminTable({
            columns,
            container: '#referrers-vue-admin-table',
            tableDataEndpoint: Craft.getActionUrl('not-found-redirects/not-found-uris/referrers-table-data', { notFoundId: {{ notFoundId }} }),
            {% if canDelete404s %}
                deleteAction: 'not-found-redirects/not-found-uris/delete-referrer',
                deleteConfirmationMessage: Craft.t('not-found-redirects', 'Are you sure you want to delete this referrer?'),
            {% endif %}
            perPage: 50,
            fullPane: false,
        });
    })();
    {% endjs %}
{% else %}
    <div class="zilch"><p>{{ 'No referrers recorded for this 404.'|t('not-found-redirects') }}</p></div>
{% endif %}
